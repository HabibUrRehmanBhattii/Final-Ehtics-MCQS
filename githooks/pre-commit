#!/bin/bash

# ============================================
# Git Pre-Commit Hook for Auto Version Bumping
# ============================================
# This script automatically updates version tags
# whenever you commit changes to source files
#
# Usage: Runs automatically before git commit
# Created: 2026-03-23

# Colors for output
GREEN='\033[0;32m'
BLUE='\033[0;34m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m' # No Color

echo -e "${BLUE}📦 Auto Version Bumping System${NC}"
echo "=================================="

# Get current date (YYYYMMDD format)
CURRENT_DATE=$(date +%Y%m%d)

# Files to check for changes
SOURCE_FILES=(
  "js/app.js"
  "js/auth.js"
  "css/style.css"
  "data/topics.json"
  "data/llqp-life/.*\.json"
  "tests/.*\.js"
  "index.html"
)

# Check if any source files have been modified or added
CHANGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)

# Detect if this is a data/version-only commit (skip if true)
if echo "$CHANGED_FILES" | grep -q "^data/topics.json$\|^index.html$"; then
  # Check if ONLY these files changed (version bump only)
  FILE_COUNT=$(echo "$CHANGED_FILES" | wc -l)
  if [ "$FILE_COUNT" -le 2 ]; then
    # Likely a version-only commit, skip auto-bumping to avoid infinite loop
    echo -e "${YELLOW}⏭️  Skipping auto-version for version-only commit${NC}"
    exit 0
  fi
fi

# Check if source files (not version-related) were modified
HAS_SOURCE_CHANGES=0
for pattern in "${SOURCE_FILES[@]}"; do
  if echo "$CHANGED_FILES" | grep -E "$pattern" | grep -v "topics.json" | grep -v "index.html" > /dev/null; then
    HAS_SOURCE_CHANGES=1
    break
  fi
done

if [ $HAS_SOURCE_CHANGES -eq 0 ]; then
  echo -e "${YELLOW}⏭️  No source file changes detected, skipping version bump${NC}"
  exit 0
fi

echo -e "${BLUE}✅ Source files changed, bumping version...${NC}"

# Extract current version tag from index.html (v=YYYYMMDDa)
OLD_TAG=$(grep -oP 'v=\K[0-9]{8}[a-z]' index.html | head -1)

if [ -z "$OLD_TAG" ]; then
  echo -e "${RED}❌ Could not find version tag (v=YYYYMMDDa) in index.html${NC}"
  exit 1
fi

OLD_DATE="${OLD_TAG:0:8}"
CURRENT_VERSION="${OLD_TAG:8:1}"

# Reset suffix to "a" when date changes; otherwise increment suffix.
if [ "$OLD_DATE" != "$CURRENT_DATE" ]; then
  NEW_VERSION="a"
else
  case "$CURRENT_VERSION" in
    a) NEW_VERSION="b" ;;
    b) NEW_VERSION="c" ;;
    c) NEW_VERSION="d" ;;
    d) NEW_VERSION="e" ;;
    e) NEW_VERSION="f" ;;
    f) NEW_VERSION="g" ;;
    g) NEW_VERSION="h" ;;
    h) NEW_VERSION="i" ;;
    i) NEW_VERSION="j" ;;
    j) NEW_VERSION="k" ;;
    k) NEW_VERSION="l" ;;
    l) NEW_VERSION="m" ;;
    m) NEW_VERSION="n" ;;
    n) NEW_VERSION="o" ;;
    o) NEW_VERSION="p" ;;
    p) NEW_VERSION="q" ;;
    q) NEW_VERSION="r" ;;
    r) NEW_VERSION="s" ;;
    s) NEW_VERSION="t" ;;
    t) NEW_VERSION="u" ;;
    u) NEW_VERSION="v" ;;
    v) NEW_VERSION="w" ;;
    w) NEW_VERSION="x" ;;
    x) NEW_VERSION="y" ;;
    y) NEW_VERSION="z" ;;
    *)
      echo -e "${YELLOW}⚠️  Version suffix reached max; rolling to next day with suffix a${NC}"
      CURRENT_DATE=$(date -d tomorrow +%Y%m%d)
      NEW_VERSION="a"
      ;;
  esac
fi

NEW_TAG="${CURRENT_DATE}${NEW_VERSION}"

echo -e "${BLUE}Version: ${OLD_TAG} → ${NEW_TAG}${NC}"

# Extract and increment cacheVersion (semantic version like v1.7.8)
CURRENT_CACHE_VERSION=$(grep -oP "cacheVersion: 'v\K[0-9]+\.[0-9]+\.[0-9]+" js/app.js | head -1)
if [ -n "$CURRENT_CACHE_VERSION" ]; then
  # Split version into major, minor, patch
  MAJOR=$(echo $CURRENT_CACHE_VERSION | cut -d. -f1)
  MINOR=$(echo $CURRENT_CACHE_VERSION | cut -d. -f2)
  PATCH=$(echo $CURRENT_CACHE_VERSION | cut -d. -f3)
  # Increment patch version
  NEW_PATCH=$((PATCH + 1))
  NEW_CACHE_VERSION="${MAJOR}.${MINOR}.${NEW_PATCH}"
fi

# Update index.html
sed -i "s/v=${OLD_TAG}/v=${NEW_TAG}/g" index.html
echo -e "${GREEN}✓ Updated index.html${NC}"

# Update data/topics.json
sed -i "s/v=${OLD_TAG}/v=${NEW_TAG}/g" data/topics.json
echo -e "${GREEN}✓ Updated data/topics.json${NC}"

# Update js/app.js hardcoded appBuildVersion
sed -i "s/appBuildVersion: '${OLD_TAG}'/appBuildVersion: '${NEW_TAG}'/g" js/app.js

# Update js/app.js cacheVersion
if [ -n "$NEW_CACHE_VERSION" ]; then
  sed -i "s/cacheVersion: 'v${CURRENT_CACHE_VERSION}'/cacheVersion: 'v${NEW_CACHE_VERSION}'/g" js/app.js
  echo -e "${GREEN}✓ Updated js/app.js (appBuildVersion & cacheVersion: v${CURRENT_CACHE_VERSION} → v${NEW_CACHE_VERSION})${NC}"
else
  echo -e "${GREEN}✓ Updated js/app.js appBuildVersion${NC}"
fi

# Stage the updated files
git add index.html data/topics.json js/app.js
echo -e "${GREEN}✓ Staged version updates${NC}"

echo -e "${BLUE}=================================="
echo -e "✅ Version bumped: ${OLD_TAG} → ${NEW_TAG}${NC}"
echo ""
