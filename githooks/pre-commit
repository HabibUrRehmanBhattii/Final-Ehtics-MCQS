#!/bin/sh

set -eu

if ! command -v node >/dev/null 2>&1; then
  echo "[pre-commit] node is not available on PATH. Skipping auto-version bump."
  exit 0
fi

STAGED_FILES="$(git diff --cached --name-only --diff-filter=ACM || true)"
if [ -z "$STAGED_FILES" ]; then
  echo "[pre-commit] No staged files. Skipping auto-version bump."
  exit 0
fi

PRECOMMIT_STAGED_FILES="$STAGED_FILES" node tools/pre-commit-version-bump.cjs

git add index.html data/topics.json js/app.js
if [ -f "data/topics-updated.json" ]; then
  git add data/topics-updated.json
fi

exit 0
